# Seeker.Bot — Environment Configuration
# Copy this file to .env and fill in your API keys

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# TELEGRAM
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LLM PROVIDERS (at least one required)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Google Gemini (required for embeddings)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (free, fast — recommended)
GROQ_API_KEY=your_groq_api_key_here

# NVIDIA NIM (free, high quality — recommended)
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here

# DeepSeek (paid, high accuracy)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Mistral (paid)
MISTRAL_API_KEY=your_mistral_api_key_here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# WEB SEARCH (optional — for /search command)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TAVILY_API_KEY=your_tavily_api_key_here
BRAVE_API_KEY=your_brave_api_key_here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LOCAL OLLAMA (optional — for /watch vision mode)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
OLLAMA_BASE_URL=http://localhost:11434

# VLM (Vision Language Model) — modelo multimodal usado pelo AFK Protocol,
# desktop_watch e demais skills de visão. Deve estar instalado no Ollama.
# Alternativas testadas (Sprint 12 — Vision 2.0):
#   qwen3.5:4b        baseline, ~4 GB VRAM, rápido
#   qwen2.5vl:7b      Qwen2.5-VL 7B, ~7 GB VRAM, melhor OCR geral
#   qwen3-vl:8b       Qwen3-VL 8B, ~9 GB VRAM, SOTA em MMBench/OCRBench
#   minicpm-v         MiniCPM-V 2.6, ~6 GB VRAM, especialista OCR
VLM_MODEL=qwen3.5:4b

# Cloud VLM fallback (Gemini 2.5 Flash) — acionado quando Ollama local
# está offline, GPU semaphore bloqueado >30s, ou confidence <0.5.
# Requer GEMINI_API_KEY definido acima.
GEMINI_VLM_FALLBACK=true
GEMINI_VLM_MODEL=gemini-2.5-flash

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# EMAIL (optional — for email monitoring skill)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your_email@gmail.com
IMAP_PASSWORD=your_app_password_here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# GIT AUTO-BACKUP (for git_automation goal)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# GitHub token for auto-backup commits (create at https://github.com/settings/tokens)
# IMPORTANT: This should point to SEEKER.AI (private) for backups, NOT Seeker.Bot (public)
GITHUB_TOKEN=your_github_token_for_backups_here
GITHUB_REPO=4pixeltechBR/Seeker.ai

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPENAI COMPATIBLE (if using other providers like LM Studio)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
