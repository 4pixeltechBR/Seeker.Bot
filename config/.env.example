# Seeker.Bot — API Keys

# ── Primary Language Models ──
# RECOMENDAÇÃO: Utilize primariamente a cascata gratuita para testes.

# [GRATUITO] Google Gemini — https://aistudio.google.com/apikey
# Free tier: 5 RPM, 100 req/dia (Gemini 2.5 Pro/Flash) Excelente para raciocínio complexo.
GEMINI_API_KEY=""

# [GRATUITO] Groq — https://console.groq.com/keys
# Free tier: 30 RPM, 14.400 req/dia. Velocidade extrema, ideal para Extração de Fatos e Roteamento.
GROQ_API_KEY=""

# [PAGO - RECOMENDADO PARA PRODUÇÃO] DeepSeek — https://platform.deepseek.com/api_keys
# Custo: ~$0.28/1M input tokens. Melhor custo-benefício para rodar 24/7.
DEEPSEEK_API_KEY=""

# [OPCIONAL] Mistral - https://console.mistral.ai/home
MISTRAL_API_KEY=""

# [OPCIONAL] NVIDIA NIM — https://build.nvidia.com/
# Free tier disponível sem limites diários.
NVIDIA_API_KEY=""

# ── Integrações de Serviço ──

# [OBRIGATÓRIO] Telegram Bot — https://t.me/BotFather
# Crie o bot e pegue o token
TELEGRAM_BOT_TOKEN=""
# ID do seu Usuário no Telegram (para acesso restrito)
TELEGRAM_ALLOWED_USERS=""

# ── Web Search ──

# [GRATUITO/LIMITADO] Tavily Search (AI-Native)
SEARCH_PROVIDER="tavily"
TAVILY_API_KEY="tvly-..."

# [GRATUITO/ILIMITADO] Brave Search — https://brave.com/search/api/
# Alternativa: Pode ser deixado em branco para usar DuckDuckGo default sem limites.
BRAVE_API_KEY=""

# ── Configurações de Monitoramento de Email ──
# Opcional: Apenas se for utilizar o Revenue Hunter para disparos e monitoramento SMTP/IMAP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="seu-email@gmail.com"
SMTP_PASSWORD="app-password-aqui"
EMAIL_RECIPIENTS="alvo@gmail.com"
IMAP_SERVER="imap.gmail.com"
IMAP_PASSWORD="app-password-aqui"
IMAP_USER="seu-email@gmail.com"

# ── GitHub Auto-Backup ──
# Token: https://github.com/settings/tokens (repo scope)
GITHUB_TOKEN=""
# Repositório PRIVADO para backup (formato: owner/repo)
GITHUB_REPO="4pixeltechBR/Seeker.ai"

# ── System ──
# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL="INFO"
