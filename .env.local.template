# ⚠️ CONFIGURAÇÃO CRÍTICA: AUTO-BACKUP APENAS SEEKER.AI
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# Este arquivo controla para ONDE o Seeker faz auto-backup de código
#
# ✅ CORRETO: GITHUB_REPO=4pixeltechBR/Seeker.ai (PRIVADO — backups)
# ❌ ERRADO:  GITHUB_REPO=4pixeltechBR/Seeker.Bot (PÚBLICO — deve ser vazio/origin)
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 🔐 GitHub Token para Auto-Backup (PRIVADO para Seeker.ai)
# Gere em: https://github.com/settings/tokens/new
# Escopos: repo, admin:repo_hook
GITHUB_TOKEN=seu_token_aqui

# 📦 Repositório de Backup (APENAS Seeker.ai — PRIVADO)
# ⚠️ NUNCA configure para Seeker.Bot!
# Seeker.Bot é público e não deve receber backups automáticos
GITHUB_REPO=4pixeltechBR/Seeker.ai

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# EXPLICAÇÃO:
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# Seeker.Bot (origem local) tem TWO remotes:
#   • origin → Seeker.Bot (público, código limpo)
#   • backup → Seeker.ai (privado, dados + código)
#
# Quando git_automation executa (a cada 6 horas):
#   1. Faz commit com mensagem LLM
#   2. Se GITHUB_TOKEN está set:
#      → Faz push para GITHUB_REPO (que é Seeker.ai)
#   3. Se GITHUB_TOKEN está vazio:
#      → Faz push para 'origin' (que é Seeker.Bot — NÃO QUEREMOS!)
#
# ✅ SOLUÇÃO: Configure GITHUB_TOKEN e GITHUB_REPO SEMPRE para Seeker.ai
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
