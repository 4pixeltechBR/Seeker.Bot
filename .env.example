# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ASSISTANT IDENTITY
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ASSISTANT_NAME=Seeker

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPERATION MODE: "cloud" (default) or "local" (100% offline via Ollama)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SEEKER_MODE=cloud
# If SEEKER_MODE=local, set your available VRAM (in GB)
LOCAL_VRAM_GB=8

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# TELEGRAM
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USERS=your_telegram_user_id
TELEGRAM_HOME_CHANNEL=your_telegram_channel_or_user_id_for_notifications
GATEWAY_TELEGRAM_ENABLED=false

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LLM PROVIDERS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Google Gemini — https://aistudio.google.com/apikey
# Requerido para embeddings e grounding
GEMINI_API_KEY=your_gemini_api_key

# Groq — https://console.groq.com/keys
# Free tier: 30 RPM, LPU de alta velocidade
GROQ_API_KEY=your_groq_api_key

# NVIDIA NIM — https://build.nvidia.com/
# Free tier: 40 RPM
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key
NVIDIA_API_KEY=your_nvidia_nim_api_key

# DeepSeek — https://platform.deepseek.com/api_keys
# Pago, melhor custo-benefício para raciocínio nativo
DEEPSEEK_API_KEY=your_deepseek_api_key

# Mistral — https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key

# Cerebras Cloud — https://cloud.cerebras.ai/
# Wafer-scale LPU ultra rápida, 30 RPM grátis
CEREBRAS_API_KEY=your_cerebras_api_key

# OpenRouter — https://openrouter.ai/
# Hub de modelos e acesso a modelos grátis adicionais
OPENROUTER_API_KEY=your_openrouter_api_key

# Kimi / Moonshot — https://platform.moonshot.cn/
KIMI_API_KEY=your_kimi_api_key

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# WEB SEARCH
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=your_tavily_api_key
BRAVE_API_KEY=your_brave_api_key
GOOGLE_SEARCH_API_KEY=your_google_custom_search_api_key
GOOGLE_SEARCH_CX=your_google_custom_search_engine_cx

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LOCAL OLLAMA (Vision)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
OLLAMA_BASE_URL=http://localhost:11434
VLM_MODEL=qwen3.5:4b

# Cloud VLM fallback (Gemini 2.5 Flash)
GEMINI_VLM_FALLBACK=true
GEMINI_VLM_MODEL=gemini-2.5-flash

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# EMAIL (Optional — for Email Monitor skill)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_RECIPIENTS=your_email@gmail.com
IMAP_SERVER=imap.gmail.com
IMAP_PASSWORD=your_app_password
IMAP_USER=your_email@gmail.com

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LOG LEVEL
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
LOG_LEVEL=INFO

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# GIT AUTO-BACKUP (Optional)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=your_user/your_private_repo

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OBSIDIAN INTEGRATION (Optional — Second Brain)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
OBSIDIAN_VAULT_PATH=C:\Users\YourUser\Obsidian\Vault
